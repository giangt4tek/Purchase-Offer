<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_purchase_offer" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.purchase.offer</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='po_order_approval']" position="after">
                <setting id="offer_approval_required" company_dependent="1" help="Require managers to approve purchase offers">
                    <field name="offer_approval_required"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
