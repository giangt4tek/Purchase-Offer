<?xml version="1.0" encoding="utf-8"?>
<odoo>


   <record model="res.groups.privilege" id="res_groups_privilege_purchase_offer">
        <field name="name">Purchase Offer</field>
        <field name="sequence">8</field>
        <field name="category_id" ref="base.module_category_supply_chain"/>
    </record>

    <record id="group_purchase_offer_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="privilege_id" ref="res_groups_privilege_purchase_offer"/>
    </record>

    <record id="group_purchase_offer_approve" model="res.groups">
        <field name="name">Approve</field>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_purchase_offer_user'))]"/>
        <field name="privilege_id" ref="res_groups_privilege_purchase_offer"/>
    </record>

    <record id="group_purchase_offer_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="sequence">100</field>
        <field name="privilege_id" ref="res_groups_privilege_purchase_offer"/>
        <field name="implied_ids" eval="[(4, ref('group_purchase_offer_user')), (4, ref('group_purchase_offer_approve'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
